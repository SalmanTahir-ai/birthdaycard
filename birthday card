<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>🎂 Happy Birthday Card</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        html, body {
            width: 100%;
            height: 100%;
            font-family: 'Poppins', Arial, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .card-container {
            width: 100%;
            height: 100%;
            max-width: 500px;
            max-height: 100vh;
            background: white;
            display: flex;
            flex-direction: column;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            overflow: hidden;
        }

        .card-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 30px 20px;
            position: relative;
            overflow: hidden;
        }

        /* PAGE STYLES */
        .page {
            position: absolute;
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 30px 20px;
            text-align: center;
            opacity: 0;
            transition: opacity 0.6s ease-in-out;
            pointer-events: none;
        }

        .page.active {
            opacity: 1;
            pointer-events: auto;
        }

        /* PAGE 1 - GREETING */
        .page-1 {
            background: linear-gradient(135deg, #FFE66D 0%, #FF9A56 100%);
            color: #333;
        }

        .page-1 h1 {
            font-size: 52px;
            font-weight: 900;
            color: white;
            margin-bottom: 15px;
            text-shadow: 3px 3px 6px rgba(0, 0, 0, 0.2);
            animation: slideDown 0.8s ease-out;
        }

        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .person-name {
            font-size: 42px;
            font-weight: bold;
            background: linear-gradient(135deg, #667eea, #764ba2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 25px;
            animation: scaleIn 0.8s ease-out;
        }

        @keyframes scaleIn {
            from { opacity: 0; transform: scale(0.8); }
            to { opacity: 1; transform: scale(1); }
        }

        .greeting-message {
            font-size: 18px;
            color: #333;
            line-height: 1.6;
            max-width: 90%;
            margin-bottom: 30px;
            animation: fadeIn 1s ease-out 0.3s both;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .emoji-large {
            font-size: 80px;
            animation: float 3s ease-in-out infinite;
            margin-bottom: 15px;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(5deg); }
        }

        /* PAGE 2 - WISHES */
        .page-2 {
            background: linear-gradient(135deg, #FF6B6B 0%, #FF8E8E 100%);
            color: white;
        }

        .page-2 h2 {
            font-size: 40px;
            font-weight: bold;
            margin-bottom: 25px;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
        }

        .wishes-container {
            display: flex;
            flex-direction: column;
            gap: 12px;
            width: 100%;
            max-width: 320px;
        }

        .wish-card {
            background: rgba(255, 255, 255, 0.2);
            padding: 12px;
            border-radius: 10px;
            border-left: 4px solid #00d4ff;
            backdrop-filter: blur(10px);
            animation: slideInLeft 0.8s ease-out forwards;
            opacity: 0;
        }

        .wish-card:nth-child(1) { animation-delay: 0.1s; }
        .wish-card:nth-child(2) { animation-delay: 0.2s; }
        .wish-card:nth-child(3) { animation-delay: 0.3s; }
        .wish-card:nth-child(4) { animation-delay: 0.4s; }

        @keyframes slideInLeft {
            from { opacity: 0; transform: translateX(-20px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .wish-card p {
            font-size: 13px;
            line-height: 1.5;
            margin: 0;
        }

        .wish-emoji {
            font-size: 18px;
            margin-right: 5px;
        }

        /* PAGE 3 - CAKE */
        .page-3 {
            background: linear-gradient(135deg, #4ECDC4 0%, #44A08D 100%);
            color: white;
        }

        .cake-emoji {
            font-size: 120px;
            animation: spin 3s linear infinite;
            margin-bottom: 20px;
        }

        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .page-3 h2 {
            font-size: 44px;
            font-weight: bold;
            margin-bottom: 20px;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
        }

        .final-message {
            font-size: 16px;
            line-height: 1.8;
            margin-bottom: 25px;
            font-weight: 500;
        }

        .page-3 .signature {
            font-size: 22px;
            font-weight: bold;
            color: #FFE66D;
        }

        /* PAGE 4 - FINAL */
        .page-4 {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .page-4 h2 {
            font-size: 48px;
            font-weight: 900;
            margin-bottom: 20px;
            text-shadow: 3px 3px 6px rgba(0, 0, 0, 0.3);
        }

        .celebration-emoji {
            font-size: 100px;
            margin-bottom: 20px;
        }

        .final-text {
            font-size: 18px;
            line-height: 1.8;
            margin-bottom: 30px;
        }

        .share-button {
            background: linear-gradient(135deg, #00d4ff, #7b2ff7);
            padding: 12px 30px;
            border: none;
            border-radius: 8px;
            color: white;
            font-weight: bold;
            cursor: pointer;
            font-size: 14px;
            transition: all 0.3s;
        }

        .share-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 212, 255, 0.4);
        }

        /* NAVIGATION */
        .nav-section {
            background: white;
            padding: 15px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-top: 1px solid #f0f0f0;
        }

        .nav-dots {
            display: flex;
            gap: 8px;
        }

        .dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #ddd;
            cursor: pointer;
            transition: all 0.3s;
        }

        .dot.active {
            background: #667eea;
            transform: scale(1.2);
        }

        .nav-buttons {
            display: flex;
            gap: 10px;
        }

        button {
            padding: 8px 16px;
            border: none;
            border-radius: 6px;
            background: #667eea;
            color: white;
            font-weight: bold;
            cursor: pointer;
            font-size: 12px;
            transition: all 0.3s;
        }

        button:hover {
            background: #764ba2;
        }

        button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .emoji-confetti {
            position: absolute;
            font-size: 24px;
            animation: fall 3s ease-in forwards;
            pointer-events: none;
        }

        @keyframes fall {
            to {
                opacity: 0;
                transform: translateY(500px) rotate(360deg);
            }
        }
    </style>
</head>
<body>
    <div class="card-container">
        <div class="card-content">
            <!-- PAGE 1: GREETING -->
            <div class="page page-1 active">
                <div class="emoji-large">🎈</div>
                <h1>Happy Birthday!</h1>
                <!-- ============================================ -->
                <!-- 👇 CHANGE NAME HERE 👇 -->
                <!-- ============================================ -->
                <div class="person-name" id="nameDisplay">Hania Tahir</div>
                <!-- ============================================ -->
                <!-- 👆 CHANGE NAME HERE 👆 -->
                <!-- ============================================ -->
                <div class="greeting-message">
                    Today is YOUR special day! 🌟<br>
                    Time to celebrate and make amazing memories!
                </div>
            </div>

            <!-- PAGE 2: WISHES -->
            <div class="page page-2">
                <h2>✨ Special Wishes ✨</h2>
                <div class="wishes-container">
                    <div class="wish-card">
                        <p><span class="wish-emoji">🌟</span> <strong>Health & Happiness:</strong> May you enjoy perfect health and endless happiness throughout this year!</p>
                    </div>
                    <div class="wish-card">
                        <p><span class="wish-emoji">💪</span> <strong>Success & Dreams:</strong> May all your dreams come true and success follow you everywhere!</p>
                    </div>
                    <div class="wish-card">
                        <p><span class="wish-emoji">❤️</span> <strong>Love & Joy:</strong> May your life be filled with love, laughter, and beautiful moments!</p>
                    </div>
                    <div class="wish-card">
                        <p><span class="wish-emoji">🚀</span> <strong>Growth & Adventure:</strong> May this year bring new adventures and help you grow stronger!</p>
                    </div>
                </div>
            </div>

            <!-- PAGE 3: CAKE -->
            <div class="page page-3">
                <div class="cake-emoji">🎂</div>
                <h2>You Are Special!</h2>
                <div class="final-message">
                    Happy Birthday to an amazing person!<br><br>
                    You deserve all the happiness in the world.<br>
                    Make this day absolutely unforgettable!
                </div>
                <div class="signature">
                    🎊 Made with Love 🎊
                </div>
            </div>

            <!-- PAGE 4: FINAL -->
            <div class="page page-4">
                <div class="celebration-emoji">🎉</div>
                <h2>Enjoy Your Day!</h2>
                <div class="final-text">
                    <p>This day is all about celebrating YOU!</p>
                    <p>Your happiness means everything.</p>
                    <p>Make it count! 🌟</p>
                </div>
                <button class="share-button" onclick="shareCard()">Share This Card 🎁</button>
            </div>
        </div>

        <!-- NAVIGATION -->
        <div class="nav-section">
            <div class="nav-dots">
                <div class="dot active" onclick="goToPage(0)"></div>
                <div class="dot" onclick="goToPage(1)"></div>
                <div class="dot" onclick="goToPage(2)"></div>
                <div class="dot" onclick="goToPage(3)"></div>
            </div>
            <div class="nav-buttons">
                <button id="prevBtn" onclick="previousPage()">← Back</button>
                <button id="nextBtn" onclick="nextPage()">Next →</button>
            </div>
        </div>
    </div>

    <script>
        let currentPage = 0;
        const totalPages = 4;

        function showPage(pageNum) {
            const pages = document.querySelectorAll('.page');
            const dots = document.querySelectorAll('.dot');
            
            pages.forEach(page => page.classList.remove('active'));
            dots.forEach(dot => dot.classList.remove('active'));
            
            pages[pageNum].classList.add('active');
            dots[pageNum].classList.add('active');
            
            document.getElementById('prevBtn').disabled = (pageNum === 0);
            document.getElementById('nextBtn').disabled = (pageNum === totalPages - 1);
            
            // Confetti on greeting page
            if (pageNum === 0) {
                createConfetti();
            }
        }

        function goToPage(pageNum) {
            currentPage = pageNum;
            showPage(currentPage);
        }

        function nextPage() {
            if (currentPage < totalPages - 1) {
                currentPage++;
                showPage(currentPage);
            }
        }

        function previousPage() {
            if (currentPage > 0) {
                currentPage--;
                showPage(currentPage);
            }
        }

        function createConfetti() {
            const emojis = ['🎉', '🎊', '🎈', '🎁', '⭐', '✨', '🌟', '🎀'];
            
            for (let i = 0; i < 25; i++) {
                const confetti = document.createElement('div');
                confetti.className = 'emoji-confetti';
                confetti.textContent = emojis[Math.floor(Math.random() * emojis.length)];
                confetti.style.left = Math.random() * 100 + '%';
                confetti.style.top = '-30px';
                confetti.style.animationDelay = Math.random() * 0.8 + 's';
                
                document.querySelector('.card-content').appendChild(confetti);
                
                setTimeout(() => confetti.remove(), 3500);
            }
        }

        function shareCard() {
            const cardUrl = window.location.href;
            const name = document.getElementById('nameDisplay').textContent;
            
            const text = `🎉 ${name} has a Birthday Card waiting for you! 🎂\n\nClick to see: ${cardUrl}`;
            
            if (navigator.share) {
                navigator.share({
                    title: 'Happy Birthday Card',
                    text: text,
                    url: cardUrl
                });
            } else {
                alert('Birthday Card URL:\n\n' + cardUrl);
            }
        }

        showPage(0);
    </script>
</body>
</html>
